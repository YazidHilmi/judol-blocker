# Copy file ini jadi .env, lalu isi value di bawah.

# Threshold decision logic (0.0 - 1.0). Skor di atas ini otomatis diblokir.
THRESHOLD_BLOCK=0.50

# URL model-service (FastAPI terpisah, biasanya port 8001)
MODEL_SERVICE_URL=http://localhost:8001

# URL frontend-overlay kita — dipakai buat generate URL overlay pengganti
# yang dikasih ke streamer setelah mereka daftar via POST /sessions
OVERLAY_BASE_URL=http://localhost:3001/index.html

# Key buat enkripsi streamKey Saweria yang disimpan di database.
# JANGAN diganti setelah ada data tersimpan (data lama gak akan bisa dibaca lagi).
# Generate dengan: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# API key internal buat proteksi endpoint /internal/sessions/active.
# HARUS SAMA PERSIS dengan INTERNAL_API_KEY di .env milik adapter/.
# Generate dengan: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=
